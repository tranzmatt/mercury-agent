# ═══════════════════════════════════════════
# Mercury — Agent Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Agent Identity
MERCURY_NAME=Mercury
MERCURY_OWNER=

# ── LLM Providers ──

# OpenAI (also covers OpenAI-compatible: DeepSeek, Together, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek (uses OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Default provider: openai | anthropic | deepseek
DEFAULT_PROVIDER=openai

# ── Telegram ──
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Memory ──
MEMORY_DIR=./memory

# ── Heartbeat ──
HEARTBEAT_INTERVAL_MINUTES=60

# ── Token Budget ──
DAILY_TOKEN_BUDGET=50000

# ── GitHub (optional) ──
# Fine-grained personal access token with repo scope
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_EMAIL=
# Default repo for GitHub tools (optional — you can also specify per-call)
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=