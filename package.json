{
  "name": "@cosmicstack/mercury-agent",
  "version": "0.3.2",
  "description": "Soul-driven AI agent with permission-hardened tools, token budgets, and multi-channel access. Runs 24/7 from CLI or Telegram.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mercury": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "ai-agent",
    "cli",
    "telegram",
    "telegram-bot",
    "personal-assistant",
    "soul-driven",
    "token-budget",
    "permissions",
    "scheduler",
    "cron",
    "skill-system",
    "deepseek",
    "openai",
    "anthropic",
    "llm"
  ],
  "author": "Cosmic Stack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmicstack-labs/mercury-agent.git"
  },
  "homepage": "https://mercury.cosmicstack.org",
  "bugs": {
    "url": "https://github.com/cosmicstack-labs/mercury-agent/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "ai": "^4.3.0",
    "chalk": "^5.4.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.42.0",
    "js-tiktoken": "^1.0.19",
    "marked": "^14.1.4",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}